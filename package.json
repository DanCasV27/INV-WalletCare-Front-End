    "@angular/platform-browser-dynamic": "^17.3.0",
    "@angular/router": "^17.3.0",
    "@ant-design/icons": "^5.3.7",
    "@ant-design/icons-angular": "^17.0.0",
    "@ctrl/tinycolor": "^4.2.0",
    "apexcharts": "^3.52.0",
    "ng-apexcharts": "1.10.0",
    "ng-zorro-antd": "^17.4.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.3"
  },
  "devDependencies": {
